# Copy to `.env` for local development: cp .env.example .env
#
# In production (Vercel), set this as an Environment Variable in the project
# settings instead of committing it. CRA embeds it at build time, so a rebuild
# is required after changing it.

# Base URL of the backend API (no trailing slash).
# Local:      http://localhost:8000
# Production:  https://your-backend.up.railway.app
REACT_APP_API_URL=http://localhost:8000
