# Copy to `.env` for local development: cp .env.example .env
#
# In production (Railway), set these as service variables in the dashboard
# instead of committing them.

# Comma-separated list of allowed CORS origins.
# Local:      *
# Production:  https://your-app.vercel.app
ALLOWED_ORIGINS=*

# Port the server binds to. Railway sets this automatically — leave it to the
# platform in production.
PORT=8000
